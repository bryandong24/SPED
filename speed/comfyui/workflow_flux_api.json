{
  "unet":   {"class_type": "UNETLoader",
             "inputs": {"unet_name": "flux1-dev.safetensors", "weight_dtype": "default"}},
  "clip":   {"class_type": "DualCLIPLoader",
             "inputs": {"clip_name1": "clip_l.safetensors", "clip_name2": "t5xxl_fp16.safetensors", "type": "flux"}},
  "vae":    {"class_type": "VAELoader",
             "inputs": {"vae_name": "ae.safetensors"}},
  "pos":    {"class_type": "CLIPTextEncode",
             "inputs": {"text": "a corgi puppy sitting in a field", "clip": ["clip", 0]}},
  "guid":   {"class_type": "FluxGuidance",
             "inputs": {"conditioning": ["pos", 0], "guidance": 3.5}},
  "latent": {"class_type": "EmptySD3LatentImage",
             "inputs": {"width": 1024, "height": 1024, "batch_size": 1}},
  "noise":  {"class_type": "RandomNoise",
             "inputs": {"noise_seed": 42}},
  "sched":  {"class_type": "BasicScheduler",
             "inputs": {"model": ["unet", 0], "scheduler": "simple", "steps": 15, "denoise": 1.0}},
  "speed":  {"class_type": "SamplerSPEED",
             "inputs": {"base_sampler": "euler", "transform": "dct", "mode": "delta_optimal",
                        "model_preset": "flux", "scales": "0.5,1.0", "delta": 0.01,
                        "manual_sigmas": "0.85", "spectrum_A": 203.615097,
                        "spectrum_beta": 1.915461, "seed": 42}},
  "guider": {"class_type": "BasicGuider",
             "inputs": {"model": ["unet", 0], "conditioning": ["guid", 0]}},
  "sca":    {"class_type": "SamplerCustomAdvanced",
             "inputs": {"noise": ["noise", 0], "guider": ["guider", 0], "sampler": ["speed", 0],
                        "sigmas": ["sched", 0], "latent_image": ["latent", 0]}},
  "decode": {"class_type": "VAEDecode",
             "inputs": {"samples": ["sca", 0], "vae": ["vae", 0]}},
  "save":   {"class_type": "SaveImage",
             "inputs": {"images": ["decode", 0], "filename_prefix": "SPEED_flux"}}
}
